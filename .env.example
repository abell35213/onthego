PORT=3000

# Yelp restaurant search
YELP_API_KEY=your_yelp_api_key_here
YELP_CACHE_TTL_SECONDS=300
YELP_CACHE_STALE_SECONDS=600

# AI concierge
OPENAI_API_KEY=your_openai_api_key_here

# TripIt OAuth
TRIPIT_API_KEY=your_tripit_api_key_here
TRIPIT_API_SECRET=your_tripit_api_secret_here
TRIPIT_TOKEN_STORE_PATH=/absolute/path/to/tripit-oauth-store.json

# Apple MapKit JS
APPLE_MAPS_TOKEN=
APPLE_MAPS_TEAM_ID=
APPLE_MAPS_KEY_ID=
APPLE_MAPS_PRIVATE_KEY=
MAPKIT_TOKEN_TTL_SECONDS=1800
