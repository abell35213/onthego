# Yelp Fusion API Configuration
# Get your API key from: https://www.yelp.com/developers/v3/manage_app

YELP_API_KEY=your_yelp_api_key_here

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Server settings
PORT=3000
YELP_CACHE_TTL_SECONDS=300
YELP_CACHE_STALE_SECONDS=600
# Legacy (milliseconds) support:
YELP_CACHE_TTL_MS=300000

# TripIt OAuth 1.0 Configuration
# Register your app at https://www.tripit.com/developer
TRIPIT_API_KEY=your_tripit_api_key_here
TRIPIT_API_SECRET=your_tripit_api_secret_here

# Apple MapKit JS Configuration
# Register a Maps ID and create a MapKit JS key at:
#   https://developer.apple.com/account/resources/identifiers/list/mapId
#   https://developer.apple.com/account/resources/authkeys/list
#
# Option A — pre-signed JWT (simplest): paste your token directly.
#   The server will return it as-is from /api/mapkit-token.
APPLE_MAPS_TOKEN=eyJraWQiOiJUTUNDOUs1MlZZIiwidHlwIjoiSldUIiwiYWxnIjoiRVMyNTYifQ.eyJpc3MiOiJCVkM4TDI5SE1VIiwiaWF0IjoxNzcyMjAxMDk3LCJleHAiOjE3NzI4NzAzOTl9.77botfLR-jUKBLOFmr1sunKi07o3sJYH04OS96HWlWMBzDkgqPFFaxP-2O2zxDrY3Pxo0-9O6XL84v6CKNgOdw
#
# Option B — server-side signing: supply the .p8 key so the server generates
#   short-lived tokens on demand (recommended for production).
APPLE_MAPS_TEAM_ID=your_apple_team_id_here
APPLE_MAPS_KEY_ID=your_mapkit_key_id_here
# Paste the full contents of your .p8 private key file with real newlines replaced by \n
APPLE_MAPS_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_KEY_CONTENT_HERE\n-----END PRIVATE KEY-----
# Token lifetime in seconds for server-signed JWTs (default: 1800 = 30 min)
MAPKIT_TOKEN_TTL_SECONDS=1800

# CORS Proxy (if needed for local development)
# Example: https://cors-anywhere.herokuapp.com/
CORS_PROXY=
